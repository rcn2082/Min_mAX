def minval(arr):
    min_val = arr[0]
    for i in arr:
        if i < min_val:
            min_val = i
    return min_val

def maxval(arr):
    max_val = arr[0]
    for i in arr:
        if i > max_val:
            max_val = i
    return max_val

def sumval(arr):
    total = 0
    for i in arr:
        total += i
    return total

def average(arr):
    return sumval(arr) / len(arr)


# Main program
n = int(input("Enter number of elements: "))

arr = list(map(int, input("Enter elements: ").split()))

print("Minimum:", min(arr))
print("Maximum:", max(arr))
print("Sum:", sum(arr))
print("Average:", sum(arr) / len(arr))
