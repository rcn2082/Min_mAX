#include<iostream>
#include<omp.h>

using namespace std;

int main(){
    
    int n;
    cout<<"Enter no of elements:";
    cin>>n;
    
    int arr[n];
    for(int i = 0; i<n; i++){
        cout<<"Enter value at index"<<i<<":";
        cin>>arr[i];
    }
    cout<<endl;
    
    int sum = 0;
    int min_value = arr[0];
    int max_value = arr[0];
    
    #pragma omp parallel for reduction(+:sum)
    for(int i = 0; i < n; i++){
        sum += arr[i];
    }
    cout<<"Sum:"<<sum<<endl;
    
    #pragma omp parallel for reduction(min:min_value)
    for(int i = 0; i< n; i++){
        if(arr[i] < min_value){
            min_value = arr[i];
        }
    }
    cout <<"Minimum:"<<min_value<<endl;

    #pragma omp parallel for reduction(max:max_value)
    for(int i = 0; i < n; i++ ){
        if(arr[i] > max_value){
            max_value = arr[i];
        }
    }
    cout<<"Maximum:"<<max_value<<endl;
    
    
    float average;
    average = sum/n;
    
    cout<<"Average:"<<average;
}
